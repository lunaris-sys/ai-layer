# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk
*.bak

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# ONNX classifier models (ai-classifier, Phase 9-γ S17). The
# Prompt-Guard model is ~85 MB and is fetched at build/install time,
# never committed.
*.onnx

# RustRover
.idea/

# Editor / OS noise
*.swp
.DS_Store

# Local-only runtime artefacts
*.sock
